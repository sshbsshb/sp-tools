# Create an empty list to store our formatted rows
table_data = []

for i in range(len(pitches)):
    row = []
    for j in range(len(diameters)):
        val_kz = k_z[i, j]
        val_kxy = k_xy[i, j]
        
        # Check if the value is NaN (invalid geometry)
        if np.isnan(val_kz):
            row.append("Invalid (D>P)")
        else:
            # Format as "kz / kxy" with 1 decimal place for kz and 2 for kxy
            row.append(f"{val_kz:.1f} / {val_kxy:.2f}")
    table_data.append(row)

# Create a Pandas DataFrame
df = pd.DataFrame(table_data, index=pitches, columns=diameters)

